#!/usr/bin/env bash
set -euo pipefail
state=${AI_GUARDRAIL_CLAUDE_TEST_STATE:?AI_GUARDRAIL_CLAUDE_TEST_STATE is required}
mkdir -p "$state"
[[ -z ${FAKE_CLAUDE_REQUIRE_PROJECT_CWD:-} || $PWD == "$FAKE_CLAUDE_REQUIRE_PROJECT_CWD" ]] || { printf 'fake claude: wrong project cwd\n' >&2; exit 44; }
printf '%s\t%s\n' "$PWD" "$*" >> "$state/calls.log"

delay_until_released() {
  local name=$1
  : > "$state/delay.$name.ready"
  while [[ ! -e $state/delay.$name.release ]]; do sleep 0.02; done
}

scope_arg() {
  local default=${1:-project}; shift || true
  SCOPE=$default
  while (($#)); do
    if [[ $1 == --scope ]]; then SCOPE=${2:?missing scope}; shift 2; else shift; fi
  done
  case $SCOPE in project|local) :;; *) printf 'fake claude: unsupported scope %s\n' "$SCOPE" >&2; exit 2;; esac
}

mutate() {
  local action=$1 plugin=$2 scope=$3 file
  file="$state/$scope.json"
  python3 - "$file" "$action" "$plugin" "$scope" <<'PY'
import json, os, pathlib, sys
path = pathlib.Path(sys.argv[1]); action, plugin, scope = sys.argv[2:]
try: data = json.loads(path.read_text()) if path.exists() else []
except json.JSONDecodeError: raise SystemExit(1)
items = {x["id"]: x for x in data}
if action == "install":
    old = items.get(plugin, {})
    default_enabled = os.environ.get("FAKE_CLAUDE_INSTALL_ENABLED", "0") == "1"
    items[plugin] = {"id": plugin, "version": str(int(old.get("version", "0")) + 1), "scope": scope, "enabled": old.get("enabled", default_enabled)}
elif action == "update":
    if plugin not in items: raise SystemExit(1)
    items[plugin]["version"] = str(int(items[plugin].get("version", "0")) + 1)
elif action == "enable":
    # 實際 CLI 對已啟用的 plugin 重複 enable 會回錯，這裡比照模擬
    if plugin not in items or items[plugin].get("enabled"): raise SystemExit(1)
    items[plugin]["enabled"] = True
elif action == "disable":
    if plugin not in items or not items[plugin].get("enabled"): raise SystemExit(1)
    items[plugin]["enabled"] = False
elif action == "uninstall": items.pop(plugin, None)
path.write_text(json.dumps(list(items.values()), sort_keys=True))
PY
  if [[ ${FAKE_CLAUDE_COMMIT_THEN_FAIL_VERIFY:-0} == 1 ]]; then : > "$state/corrupt-next-list"; fi
}

[[ ${1:-} == plugin ]] || { printf 'fake claude: unsupported command\n' >&2; exit 2; }
[[ ${FAKE_CLAUDE_MISSING_SUBCOMMAND:-} != "${2:-}" ]] || { printf 'fake claude: unsupported plugin operation\n' >&2; exit 2; }
[[ ${3:-} != --help ]] || exit 0
case ${2:-} in
  list)
    [[ ${FAKE_CLAUDE_DELAY_OPERATION:-} != list ]] || delay_until_released list
    [[ ${3:-} == --json ]] || exit 2
    if [[ -n ${FAKE_CLAUDE_LIST_OUTPUT:-} ]]; then printf '%s\n' "$FAKE_CLAUDE_LIST_OUTPUT"; exit 0; fi
    if [[ ${FAKE_CLAUDE_CORRUPT_LIST:-0} == 1 || -e $state/corrupt-next-list ]]; then rm -f "$state/corrupt-next-list"; printf '{corrupt\n'; exit 0; fi
    python3 - "$state/project.json" "$state/local.json" <<'PY'
import json, pathlib, sys
out=[]
for name in sys.argv[1:]:
 p=pathlib.Path(name)
 if p.exists(): out.extend(json.loads(p.read_text()))
print(json.dumps(out, sort_keys=True))
PY
    ;;
  marketplace)
    case ${3:-} in
      add) scope_arg project "${@:4}"; printf '%s\n' "${4:-}" > "$state/marketplace.$SCOPE";;
      list)
        [[ ${4:-} == --json ]] || exit 2
        if [[ -n ${FAKE_CLAUDE_MARKETPLACE_LIST_OUTPUT:-} ]]; then printf '%s\n' "$FAKE_CLAUDE_MARKETPLACE_LIST_OUTPUT"; exit 0; fi
        if [[ ${FAKE_CLAUDE_UNREGISTERED_MARKETPLACE:-0} == 1 ]]; then printf '[]\n'; exit 0; fi
        python3 - "$state" <<'PY'
import json,pathlib,sys
# 模擬實際 CLI 的結構化來源格式：{"source":"directory","path":...}
root=pathlib.Path(sys.argv[1]); out=[]
for scope in ('project','local'):
 p=root/f'marketplace.{scope}'
 if p.exists():
  path=p.read_text().strip()
  out.append({'name':'ai-guardrail-kit','source':'directory','path':path,'installLocation':path})
print(json.dumps(out))
PY
        ;;
      *) exit 2;;
    esac
    ;;
  help) exit 0;;
  install|update|uninstall|enable|disable)
    operation=$2; plugin=${3:?missing plugin}; scope_arg project "${@:4}"
    [[ ${FAKE_CLAUDE_DELAY_OPERATION:-} != "$operation" ]] || delay_until_released "$operation"
    mode=${plugin%@*}
    if [[ $operation == install && ${FAKE_CLAUDE_FAIL_INSTALL:-} == "$mode" ]]; then exit 42; fi
    if [[ $operation == uninstall && ${FAKE_CLAUDE_FAIL_REMOVE:-} == "$mode" ]]; then exit 42; fi
    if [[ $operation == enable && ${FAKE_CLAUDE_FAIL_ENABLE:-} == "$mode" ]]; then exit 42; fi
    mutate "$operation" "$plugin" "$SCOPE"
    [[ ${FAKE_CLAUDE_DELAY_AFTER_OPERATION:-} != "$operation" ]] || delay_until_released "after-$operation"
    ;;
  *) printf 'fake claude: unsupported plugin operation\n' >&2; exit 2;;
esac
