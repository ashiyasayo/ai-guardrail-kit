#!/usr/bin/env bash
set -euo pipefail
state=${AI_GUARDRAIL_TEST_STATE:?AI_GUARDRAIL_TEST_STATE is required}
mkdir -p "$state"
installed="$state/installed"
touch "$installed"

fail_if_requested() {
  local operation=$1 plugin=${2:-}
  if [[ ${FAKE_CODEX_FAIL_OPERATION:-} == "$operation" &&
        ( -z ${FAKE_CODEX_FAIL_PLUGIN:-} || ${FAKE_CODEX_FAIL_PLUGIN} == "$plugin" ) ]]; then
    printf 'fake codex: forced %s failure for %s\n' "$operation" "$plugin" >&2
    exit 42
  fi
}

count_operation() {
  local operation=$1 count_file n=0
  count_file="$state/${operation}.count"
  [[ -f $count_file ]] && read -r n < "$count_file"
  n=$((n + 1)); printf '%s\n' "$n" > "$count_file"
  if [[ ${FAKE_CODEX_DELAY_OPERATION:-} == "$operation" ||
        ${FAKE_CODEX_DELAY_OPERATION:-} == "$operation:$n" ]]; then
    : > "$state/delay.$operation.$n.ready"
    sleep 2
  fi
  if [[ ${FAKE_CODEX_FAIL_OPERATION:-} == "$operation:$n" ]]; then exit 42; fi
}

[[ ${1:-} == plugin ]] || { printf 'fake codex: unsupported command\n' >&2; exit 2; }
case ${2:-} in
  list)
    count_operation list
    fail_if_requested list
    if [[ -n ${FAKE_CODEX_LIST_JSON:-} ]]; then printf '%s\n' "$FAKE_CODEX_LIST_JSON"; exit 0; fi
    python3 - "$installed" <<'PY'
import json, pathlib, sys
names = [x for x in pathlib.Path(sys.argv[1]).read_text().splitlines() if x]
print(json.dumps({"installed": [
    {"pluginId": n, "name": n.split("@", 1)[0],
     "marketplaceName": n.split("@", 1)[1], "installed": True,
     "enabled": True} for n in names
]}))
PY
    ;;
  add)
    plugin=${3:?missing plugin}; count_operation add; fail_if_requested add "$plugin"
    grep -Fxq "$plugin" "$installed" || printf '%s\n' "$plugin" >> "$installed"
    generation_file="$state/generation.${plugin//@/_}"
    generation=0; [[ -f $generation_file ]] && read -r generation < "$generation_file"
    printf '%s\n' "$((generation + 1))" > "$generation_file"
    if [[ ${FAKE_CODEX_DELAY_AFTER_OPERATION:-} == add ]]; then sleep 2; fi
    ;;
  remove)
    plugin=${3:?missing plugin}; count_operation remove; fail_if_requested remove "$plugin"
    tmp="$state/installed.tmp"
    grep -Fxv "$plugin" "$installed" > "$tmp" || true
    mv "$tmp" "$installed"
    ;;
  marketplace)
    [[ ${3:-} == upgrade ]] || { printf 'fake codex: unsupported marketplace operation\n' >&2; exit 2; }
    count_operation upgrade
    fail_if_requested upgrade "${4:-}"
    printf '%s\n' "${4:-}" > "$state/upgrade.args"
    ;;
  *) printf 'fake codex: unsupported plugin operation\n' >&2; exit 2 ;;
esac
