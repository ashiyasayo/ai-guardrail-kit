#!/usr/bin/env bash
set -uo pipefail
script_dir=$(cd "$(dirname "$0")" && pwd -P)
repo=$(cd "$script_dir/.." && pwd -P)
# shellcheck source=claude-mode-lib.sh
source "$script_dir/claude-mode-lib.sh"

usage() { printf 'usage: select-claude-mode <mode>|--remove [--scope project|local] [project-dir]\n' >&2; exit 2; }
action=${1:-}; shift || true
remove=0
case $action in --remove) remove=1;; decomposition-gate|harness|integrated-harness) target=$action;; *) usage;; esac
scope=project
if [[ ${1:-} == --scope ]]; then [[ $# -ge 2 ]] || usage; scope=$2; shift 2; fi
agk_claude_validate_scope "$scope" >/dev/null 2>&1 || usage
[[ $# -le 1 ]] || usage
project=${1:-.}
[[ -d $project ]] || { printf 'project directory does not exist: %s\n' "$project" >&2; exit 1; }
project=$(cd "$project" && pwd -P) || exit 1
command -v claude >/dev/null || { printf 'claude executable is unavailable\n' >&2; exit 1; }
command -v python3 >/dev/null || { printf 'python3 executable is unavailable\n' >&2; exit 1; }
ccli() { (cd "$project" && claude "$@"); }
if (( remove )); then package_target=''; else package_target=$target; fi
agk_claude_validate_package "$repo" "$package_target" || { printf 'Claude package validation failed\n' >&2; exit 1; }
for capability in list install update uninstall enable disable; do
  ccli plugin "$capability" --help >/dev/null 2>&1 || { printf 'required Claude plugin capability is unavailable: %s\n' "$capability" >&2; exit 1; }
done
marketplaces=$(mktemp "${TMPDIR:-/tmp}/ai-guardrail-claude-marketplaces.XXXXXX") || exit 1
if ! ccli plugin marketplace list --json >"$marketplaces"; then rm -f "$marketplaces"; printf 'required Claude marketplace capability is unavailable\n' >&2; exit 1; fi
expected_marketplace=$(cd "$repo" && pwd -P) || { rm -f "$marketplaces"; exit 1; }
python3 - "$marketplaces" "$AGK_CLAUDE_MARKETPLACE" "$expected_marketplace" <<'PY' || { rm -f "$marketplaces"; printf 'ai-guardrail-kit marketplace is not registered as a resolvable local directory source\n' >&2; exit 1; }
import json,pathlib,sys
try: data=json.loads(pathlib.Path(sys.argv[1]).read_text())
except (OSError,UnicodeError,json.JSONDecodeError): raise SystemExit(1)
if not isinstance(data,list) or any(not isinstance(x,dict) or not isinstance(x.get('name'),str) for x in data): raise SystemExit(1)
matches=[x for x in data if x['name']==sys.argv[2]]
if len(matches)!=1: raise SystemExit(1)
entry=matches[0]
# 僅接受 directory 來源：selector 驗證的是本地 checkout 的套件內容，
# git/github 來源安裝自遠端快取，與本地驗證結果無法對應
if entry.get('source')!='directory' or not isinstance(entry.get('path'),str): raise SystemExit(1)
try: actual=pathlib.Path(entry['path']).expanduser().resolve(strict=True)
except (OSError,RuntimeError): raise SystemExit(1)
if actual != pathlib.Path(sys.argv[3]).resolve(strict=True): raise SystemExit(1)
PY
rm -f "$marketplaces"

snapshot=$(mktemp "${TMPDIR:-/tmp}/ai-guardrail-claude-state.XXXXXX") || exit 1
listing=$(mktemp "${TMPDIR:-/tmp}/ai-guardrail-claude-list.XXXXXX") || { rm -f "$snapshot"; exit 1; }
trap 'rm -f "$snapshot" "$listing"' EXIT
ccli plugin list --json >"$listing" || { printf 'could not inspect Claude plugin state\n' >&2; exit 1; }
python3 - "$listing" "$snapshot" "$AGK_CLAUDE_MARKETPLACE" "${AGK_CLAUDE_MODES[@]}" <<'PY' || { printf 'could not parse Claude plugin state\n' >&2; exit 1; }
import json, pathlib, sys
source, dest, market, *modes = sys.argv[1:]
data=json.loads(pathlib.Path(source).read_text())
if not isinstance(data,list): raise SystemExit(1)
rows=[]
for x in data:
    if not isinstance(x,dict) or not isinstance(x.get('id'),str) or x.get('scope') not in ('project','local','user') or not isinstance(x.get('enabled'),bool): raise SystemExit(1)
    if '@' in x['id']:
        name, origin=x['id'].rsplit('@',1)
        if origin==market and name in modes:
            if x['scope']=='user': raise SystemExit(1)
            rows.append((name,x['scope'],'1' if x['enabled'] else '0'))
pathlib.Path(dest).write_text(''.join('\t'.join(x)+'\n' for x in sorted(rows)))
PY

plugin() { printf '%s@%s' "$1" "$AGK_CLAUDE_MARKETPLACE"; }
remove_all() {
  local m s enabled failed=0
  while IFS=$'\t' read -r m s enabled; do [[ -z $m ]] && continue; ccli plugin uninstall "$(plugin "$m")" --scope "$s" >/dev/null || failed=1; done < <(sort -u "$snapshot")
  return "$failed"
}
restore() {
  local m s enabled
  # Clear whatever managed state remains, then replay the exact saved tuples.
  for s in project local; do for m in "${AGK_CLAUDE_MODES[@]}"; do ccli plugin uninstall "$(plugin "$m")" --scope "$s" >/dev/null 2>&1 || true; done; done
  while IFS=$'\t' read -r m s enabled; do
    [[ -z $m ]] && continue
    ccli plugin install "$(plugin "$m")" --scope "$s" >/dev/null 2>&1 || continue
    if [[ $enabled == 1 ]]; then ccli plugin enable "$(plugin "$m")" --scope "$s" >/dev/null 2>&1 || true
    else ccli plugin disable "$(plugin "$m")" --scope "$s" >/dev/null 2>&1 || true; fi
  done < "$snapshot"
  ccli plugin list --json >"$listing" 2>/dev/null || return 1
  if python3 - "$listing" "$snapshot" "$AGK_CLAUDE_MARKETPLACE" "${AGK_CLAUDE_MODES[@]}" <<'PY' >/dev/null 2>&1
import json,pathlib,sys
source,wanted,market,*modes=sys.argv[1:]; data=json.loads(pathlib.Path(source).read_text()); rows=[]
for x in data:
 if '@' in x.get('id',''):
  n,o=x['id'].rsplit('@',1)
  if o==market and n in modes and x.get('scope') in ('project','local'): rows.append((n,x['scope'],'1' if x.get('enabled') else '0'))
actual=''.join('\t'.join(x)+'\n' for x in sorted(rows))
raise SystemExit(0 if actual==pathlib.Path(wanted).read_text() else 1)
PY
  then return 0; else return 1; fi
}
fail_and_restore() { if restore; then printf 'selection failed; previous managed state restored\n' >&2; else printf 'selection failed; managed state restoration incomplete\n' >&2; fi; exit 1; }

committed=0
on_signal() {
  local status=$1
  trap - INT TERM HUP
  if (( committed )); then printf 'update applied but verification interrupted\n' >&2
  else restore >/dev/null 2>&1 || true; fi
  exit "$status"
}
trap 'on_signal 130' INT
trap 'on_signal 143' TERM
trap 'on_signal 129' HUP

if (( ! remove )) && [[ $(wc -l <"$snapshot" | tr -d ' ') == 1 ]] && grep -Fxq "$target"$'\t'"$scope"$'\t1' "$snapshot"; then
  "$script_dir/verify-claude-mode" "$target" "$project" >/dev/null || { printf 'selection failed; previous managed state restored\n' >&2; exit 1; }
  ccli plugin update "$(plugin "$target")" --scope "$scope" >/dev/null || { printf 'selection failed; previous managed state restored\n' >&2; exit 1; }
  committed=1
  if [[ -n ${AI_GUARDRAIL_CLAUDE_TEST_PAUSE_AFTER_COMMIT:-} ]]; then
    : > "$AI_GUARDRAIL_CLAUDE_TEST_PAUSE_AFTER_COMMIT.ready"
    while [[ ! -e $AI_GUARDRAIL_CLAUDE_TEST_PAUSE_AFTER_COMMIT.release ]]; do sleep 0.02; done
  fi
  "$script_dir/verify-claude-mode" "$target" "$project" >/dev/null || { printf 'update applied but verification failed\n' >&2; exit 1; }
  printf 'Updated Claude mode %s (%s); start a new Claude Code session to activate it.\n' "$target" "$scope"; exit 0
fi

changed=$(awk -F '\t' '{print $2}' "$snapshot" | sort -u | paste -sd, -)
remove_all || fail_and_restore
already_enabled() {
  # 實際 CLI 的 install 會自動 enable，對已啟用的 plugin 重複 enable 會回錯，
  # 先查目前狀態決定是否需要 enable。回傳 0=已啟用、1=未啟用、2=無法判定
  ccli plugin list --json >"$listing" || return 2
  python3 - "$listing" "$(plugin "$target")" "$scope" <<'PY'
import json,pathlib,sys
try: data=json.loads(pathlib.Path(sys.argv[1]).read_text())
except (OSError,UnicodeError,json.JSONDecodeError): raise SystemExit(2)
if not isinstance(data,list): raise SystemExit(2)
raise SystemExit(0 if any(isinstance(x,dict) and x.get('id')==sys.argv[2] and x.get('scope')==sys.argv[3] and x.get('enabled') is True for x in data) else 1)
PY
}
if (( ! remove )); then
  ccli plugin install "$(plugin "$target")" --scope "$scope" >/dev/null || fail_and_restore
  already_enabled; enabled_state=$?
  (( enabled_state != 2 )) || fail_and_restore
  if (( enabled_state == 1 )); then ccli plugin enable "$(plugin "$target")" --scope "$scope" >/dev/null || fail_and_restore; fi
  "$script_dir/verify-claude-mode" "$target" "$project" >/dev/null || fail_and_restore
  printf 'Selected Claude mode %s (%s); start a new Claude Code session to activate it.\n' "$target" "$scope"
else
  "$script_dir/verify-claude-mode" --no-managed-mode "$project" >/dev/null || fail_and_restore
  [[ -z $changed ]] && changed=none
  printf 'Removed Claude managed modes; changed scopes: %s; start a new Claude Code session to deactivate them.\n' "$changed"
fi
