#!/usr/bin/env bash
set -uo pipefail
script_dir=$(cd "$(dirname "$0")" && pwd -P)
repo=$(cd "$script_dir/.." && pwd -P)
# shellcheck source=claude-mode-lib.sh
source "$script_dir/claude-mode-lib.sh"

usage() { printf 'usage: verify-claude-mode <mode> [project-dir] | --no-managed-mode [project-dir]\n' >&2; exit 2; }
target=${1:-}; shift || true
[[ $# -le 1 ]] || usage
case $target in
  --no-managed-mode) empty=1;;
  decomposition-gate|harness|integrated-harness) empty=0;;
  *) usage;;
esac
project=${1:-.}
[[ -d $project ]] || { printf 'project directory does not exist: %s\n' "$project" >&2; exit 1; }
project=$(cd "$project" && pwd -P) || exit 1
if (( ! empty )); then agk_claude_validate_package "$repo" "$target" || { printf 'Claude package validation failed\n' >&2; exit 1; }; fi

raw=$(mktemp "${TMPDIR:-/tmp}/ai-guardrail-claude-verify.XXXXXX") || exit 1
trap 'rm -f "$raw"' EXIT
(cd "$project" && claude plugin list --json) >"$raw" || { printf 'could not inspect Claude plugin state\n' >&2; exit 1; }
python3 - "$raw" "$AGK_CLAUDE_MARKETPLACE" "${AGK_CLAUDE_MODES[@]}" <<'PY' || { printf 'unsupported managed user-scope installation\n' >&2; exit 1; }
import json,pathlib,sys
data=json.loads(pathlib.Path(sys.argv[1]).read_text()); market=sys.argv[2]; modes=set(sys.argv[3:])
if not isinstance(data,list): raise SystemExit(1)
for x in data:
 if not isinstance(x,dict) or not isinstance(x.get('id'),str) or x.get('scope') not in ('project','local','user') or not isinstance(x.get('enabled'),bool): raise SystemExit(1)
 if '@' in x['id']:
  n,o=x['id'].rsplit('@',1)
  if n in modes and o==market and x['scope']=='user': raise SystemExit(1)
PY

effective=$(cd "$project" && agk_claude_effective_modes) || { printf 'could not inspect Claude plugin state\n' >&2; exit 1; }
if (( empty )); then
  [[ -z $effective ]] || { while IFS= read -r mode; do [[ -n $mode ]] && printf 'managed mode remains: %s\n' "$mode" >&2; done <<<"$effective"; exit 1; }
  printf 'Verified no managed Claude mode.\n'; exit 0
fi
if [[ $effective != "$target" ]]; then
  for scope in project local; do
    modes=$(cd "$project" && agk_claude_list_scope "$scope") || { printf 'could not inspect %s scope\n' "$scope" >&2; exit 1; }
    while IFS= read -r mode; do [[ -n $mode && $mode != "$target" ]] && printf 'conflict: %s (%s)\n' "$mode" "$scope" >&2; done <<<"$modes"
  done
  printf 'effective mode is not exactly %s\n' "$target" >&2; exit 1
fi
found=0
for scope in project local; do (cd "$project" && agk_claude_is_enabled "$target" "$scope") && found=1; done
(( found )) || { printf 'enabled target installation is missing\n' >&2; exit 1; }

printf 'Verified Claude mode %s.\n' "$target"
