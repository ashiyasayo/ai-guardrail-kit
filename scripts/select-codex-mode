#!/usr/bin/env bash
set -uo pipefail
script_dir=$(cd "$(dirname "$0")" && pwd -P)
repo=$(cd "$script_dir/.." && pwd -P)
# shellcheck source=codex-mode-lib.sh
source "$script_dir/codex-mode-lib.sh"

mode=${1:-}
remove=0
if [[ $mode == --remove ]]; then remove=1; else agk_valid_mode "$mode" || { agk_die "expected --remove or one of: decomposition-gate, harness, integrated-harness"; exit 2; }; fi
project=$(agk_resolve_project "${2:-.}") || exit 1
agk_validate_config "$project" || exit 1

config="$project/.codex/config.toml"
snapshot=$(mktemp -d "${TMPDIR:-/tmp}/ai-guardrail-rollback.XXXXXX") || exit 1
trap '(( BASH_SUBSHELL > 0 )) || rm -rf "$snapshot"' EXIT
config_existed=0
if [[ -e $config ]]; then
  # Validation and snapshotting cannot be atomic across this external path; the
  # documented TOCTOU boundary remains between agk_validate_config and cp.
  if [[ ${AI_GUARDRAIL_TEST_FAIL_SNAPSHOT_COPY:-0} == 1 ]] || ! cp -p "$config" "$snapshot/config"; then
    agk_die 'could not snapshot config'; rm -rf "$snapshot"; exit 1
  fi
  config_existed=1
fi
if ! agk_installed_modes > "$snapshot/modes"; then agk_die 'could not inspect installed plugins'; exit 1; fi

rollback() {
  local failed=0 current original old m
  if ! current=$(agk_installed_modes 2>/dev/null); then failed=1; current=''; fi
  for m in "${AGK_MODES[@]}"; do
    if grep -Fxq "$m" <<<"$current" && ! grep -Fxq "$m" "$snapshot/modes"; then
      codex plugin remove "$(agk_plugin_path "$m")" >/dev/null 2>&1 || failed=1
    fi
  done
  if ! current=$(agk_installed_modes 2>/dev/null); then failed=1; current=''; fi
  while IFS= read -r old; do
    [[ -z $old ]] && continue
    grep -Fxq "$old" <<<"$current" || codex plugin add "$(agk_plugin_path "$old")" >/dev/null 2>&1 || failed=1
  done < "$snapshot/modes"
  agk_restore_config "$project" "$snapshot/config" "$config_existed" || failed=1
  original=$(<"$snapshot/modes")
  if ! current=$(agk_installed_modes 2>/dev/null) || [[ $original != "$current" ]] ||
     { [[ $config_existed == 1 ]] && ! cmp -s "$snapshot/config" "$config"; } ||
     { [[ $config_existed == 1 ]] && [[ $(agk_file_mode "$snapshot/config") != $(agk_file_mode "$config") ]]; } ||
     { [[ $config_existed == 0 ]] && [[ -e $config ]]; }; then failed=1; fi
  if (( failed )); then agk_die 'switch failed; rollback also failed'; else agk_die 'switch failed; rollback succeeded'; fi
  return 1
}

cleanup() { rm -rf "$snapshot"; }
on_signal() { local sig=$1 status=$2; trap - INT TERM HUP; rollback >/dev/null 2>&1 || true; cleanup; exit "$status"; }
trap cleanup EXIT
trap 'on_signal INT 130' INT
trap 'on_signal TERM 143' TERM
trap 'on_signal HUP 129' HUP
for other in "${AGK_MODES[@]}"; do
  if grep -Fxq "$other" "$snapshot/modes"; then
    codex plugin remove "$(agk_plugin_path "$other")" >/dev/null || { rollback; exit 1; }
  fi
done
if (( ! remove )); then
  codex plugin add "$(agk_plugin_path "$mode")" >/dev/null || { rollback; exit 1; }
fi

if (( remove )); then
  agk_remove_config_block "$project" || { rollback; exit 1; }
  "$script_dir/verify-codex-mode" --no-managed-mode "$project" >/dev/null || { rollback; exit 1; }
  printf 'Removed Codex guardrail mode; start a new thread to deactivate it.\n'
else
  block="$snapshot/block"
  agk_render_block "$mode" "$repo" > "$block"
  agk_replace_config "$project" "$block" || { rollback; exit 1; }
  "$script_dir/verify-codex-mode" "$mode" "$project" >/dev/null || { rollback; exit 1; }
  printf 'Selected Codex mode %s; start a new thread to activate it.\n' "$mode"
fi
